---
interface Props {
  tags: Array<{ slug: string; label: string }>;
  class?: string;
}

const { tags, class: className } = Astro.props;
---

{tags.length > 0 && (
  <ul class:list={["flex flex-wrap gap-2 list-none p-0 m-0", className]}>
    {tags.map((tag) => (
      <li>
        <a href={`/tag/${tag.slug}`} class="inline-block py-0.5 px-3 text-sm text-text-secondary bg-surface rounded-sm no-underline transition-[color_120ms,background_120ms] hover:text-text hover:bg-border">{tag.label}</a>
      </li>
    ))}
  </ul>
)}
