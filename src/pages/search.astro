---
export const prerender = false;

import { search } from "emdash";
import Base from "../layouts/Base.astro";

const query = Astro.url.searchParams.get("q")?.trim() || "";

const { items: results } = query
  ? await search(query, { collections: ["posts"], limit: 30 })
  : { items: [] };
---

<Base
  title={query ? `Tìm kiếm: ${query}` : "Tìm kiếm"}
  description="Tìm kiếm bài viết"
>
  <section class="max-w-max-width mx-auto py-8 px-6 pb-16">
    <h1 class="text-2xl mb-6">Tìm kiếm</h1>

    <form method="get" action="/search" class="flex gap-2 mb-8">
      <input
        type="search"
        name="q"
        value={query}
        placeholder="Tìm kiếm bài viết..."
        class="flex-1 py-2 px-4 text-base border border-border rounded-sm bg-bg text-text focus:outline-none focus:border-accent"
        autofocus
      />
      <button type="submit" class="py-2 px-6 text-base bg-accent text-on-accent border-none rounded-sm cursor-pointer font-medium hover:opacity-90">Tìm kiếm</button>
    </form>

    {
      query && (
        <p class="text-muted mb-6">
          {results.length === 0
            ? `Không có kết quả cho "${query}"`
            : `${results.length} kết quả cho "${query}"`}
        </p>
      )
    }

    {
      results.length > 0 && (
        <ol class="list-none p-0 m-0 flex flex-col">
          {results.map((result) => (
            <li class="py-6 px-0 border-b border-border-subtle first:pt-0 last:border-b-0">
              <a
                href={`/posts/${result.slug ?? result.id}`}
                class="block no-underline text-inherit"
              >
                <h2 class="text-xl font-semibold leading-snug mb-2 transition-colors duration-120 hover:text-accent">
                  {result.title ?? "Không có tiêu đề"}
                </h2>
                {result.snippet && (
                  <p class="text-base leading-relaxed text-text-secondary" set:html={result.snippet} />
                )}
              </a>
            </li>
          ))}
        </ol>
      )
    }

    {!query && <p class="text-muted">Nhập từ khóa để tìm kiếm bài viết.</p>}
  </section>
</Base>

<style>
  .result-snippet :global(mark) {
    background: var(--color-accent-ring);
    color: inherit;
    padding: 0 0.1em;
    border-radius: 2px;
  }
</style>
