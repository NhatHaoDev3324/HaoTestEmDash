---
import { getEmDashCollection, getTermsForEntries } from "emdash";
import Base from "../../layouts/Base.astro";
import { getReadingTime } from "../../utils/reading-time";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
  orderBy: { published_at: "desc" },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const tagsByEntry = await getTermsForEntries(
  "posts",
  posts.map((p) => p.data.id),
  "tag",
);

const postsWithTags = posts.map((post) => ({
  post,
  tags: tagsByEntry.get(post.data.id) ?? [],
  bylines: post.data.bylines ?? [],
}));

const formatDate = (date: Date) =>
  date.toLocaleDateString("vi-VN", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Base title="Tất cả bài viết" description="Duyệt tất cả bài viết">
  <div class="max-w-content-width mx-auto py-8 px-6 pb-16 max-[600px]:py-6 max-[600px]:px-4 max-[600px]:pb-12">
    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight mb-2 max-[600px]:text-3xl">Tất cả bài viết</h1>
      <p class="text-lg text-muted">
        {posts.length}
        {posts.length === 1 ? "bài viết" : "bài viết"}
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-muted text-lg">Chưa có bài viết nào.</p>
      ) : (
        <div class="flex flex-col">
          {postsWithTags.map(({ post, tags, bylines }) => (
            <article class="py-8 px-0 border-b border-border-subtle first:pt-0 last:border-b-0 group/post">
              <a href={`/posts/${post.id}`} class="block no-underline text-inherit">
                <div class="flex items-center gap-3 text-sm text-muted mb-2">
                  {bylines.length > 0 && (
                    <>
                      <div class="flex items-center gap-0.5">
                        {bylines.slice(0, 2).map((credit, index) => (
                          <>
                            {index > 0 && <span class="text-muted mr-0.5">,</span>}
                            <span class="inline-flex items-center gap-1">
                              {credit.byline.avatarMediaId && (
                                <img
                                  src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
                                  alt={credit.byline.displayName}
                                  class="w-avatar-sm h-avatar-sm rounded-full object-cover"
                                />
                              )}
                              <span class="font-medium text-text-secondary">
                                {credit.byline.displayName}
                              </span>
                            </span>
                          </>
                        ))}
                        {bylines.length > 2 && (
                          <span class="text-xs text-muted ml-0.5">+{bylines.length - 2}</span>
                        )}
                      </div>
                      <span class="w-0.75 h-0.75 rounded-full bg-muted shrink-0" />
                    </>
                  )}
                  {post.data.publishedAt && (
                    <time>{formatDate(post.data.publishedAt)}</time>
                  )}
                  {post.data.publishedAt && <span class="w-0.75 h-0.75 rounded-full bg-muted shrink-0" />}
                  <span>{getReadingTime(post.data.content)} phút đọc</span>
                </div>
                <h2 class="text-2xl font-semibold leading-snug tracking-snug mb-2 transition-colors group-hover/post:text-accent max-[600px]:text-xl">{post.data.title}</h2>
                {post.data.excerpt && (
                  <p class="text-lg leading-relaxed text-text-secondary">{post.data.excerpt}</p>
                )}
              </a>
              {tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {tags.slice(0, 3).map((t) => (
                    <a href={`/tag/${t.slug}`} class="inline-block py-0.5 px-2 text-xs text-text-secondary bg-surface rounded-sm no-underline transition-[color_120ms,background_120ms] hover:text-text hover:bg-border">
                      {t.label}
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      )
    }
  </div>
</Base>
